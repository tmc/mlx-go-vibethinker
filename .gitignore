# Local agent/workflow process residue — not module content.
/.claude/
/.workflow-*.js

# Real-model weights for the realmodel smoke test are multi-GB HF exports kept
# outside the repo (~/models-tmp by default); never commit model artifacts.
/models-tmp/
*.safetensors

# Built command binaries: go build ./cmd/<name> drops them at the repo root.
/vibethinker-eval
/vibethinker-methodcompare
/vibethinker-realmodel
/vibethinker-train

